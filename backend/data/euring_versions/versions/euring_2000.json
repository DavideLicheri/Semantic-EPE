  "validation_rules": [
    {
      "field_name": "scheme_code",
      "rule_type": "format",
      "rule_expression": "len(value) == 4 and value.isalnum() and value.isupper()",
      "error_message": "Scheme code must be 4 uppercase alphanumeric characters"
    },
    {
      "field_name": "ring_prefix",
      "rule_type": "format",
      "rule_expression": "len(value) == 3 and value.isalnum() and value.isupper()",
      "error_message": "Ring prefix must be 3 uppercase alphanumeric characters"
    },
    {
      "field_name": "separator",
      "rule_type": "exact",
      "rule_expression": "value == '...'",
      "error_message": "Separator must be exactly '...'"
    },
    {
      "field_name": "ring_number",
      "rule_type": "format",
      "rule_expression": "len(value) == 7 and value.isdigit()",
      "error_message": "Ring number must be exactly 7 digits"
    },
    {
      "field_name": "ring_suffix",
      "rule_type": "format",
      "rule_expression": "len(value) == 2 and value.isalpha() and value.isupper()",
      "error_message": "Ring suffix must be 2 uppercase letters"
    },
    {
      "field_name": "date_first",
      "rule_type": "format",
      "rule_expression": "len(value) == 5 and value.isdigit()",
      "error_message": "First date must be exactly 5 digits"
    },
    {
      "field_name": "date_current",
      "rule_type": "format",
      "rule_expression": "len(value) == 5 and value.isdigit()",
      "error_message": "Current date must be exactly 5 digits"
    },
    {
      "field_name": "age_code",
      "rule_type": "range",
      "rule_expression": "value.isdigit() and len(value) == 1",
      "error_message": "Age code must be a single digit"
    },
    {
      "field_name": "latitude_sign",
      "rule_type": "exact",
      "rule_expression": "value in ['+', '-']",
      "error_message": "Latitude sign must be + or -"
    },
    {
      "field_name": "longitude_sign",
      "rule_type": "exact",
      "rule_expression": "value in ['+', '-']",
      "error_message": "Longitude sign must be + or -"
    },
    {
      "field_name": "latitude_value",
      "rule_type": "format",
      "rule_expression": "len(value) == 6 and value.isdigit()",
      "error_message": "Latitude value must be exactly 6 digits"
    },
    {
      "field_name": "longitude_value",
      "rule_type": "format",
      "rule_expression": "len(value) == 6 and value.isdigit()",
      "error_message": "Longitude value must be exactly 6 digits"
    },
    {
      "field_name": "empty_fields_1",
      "rule_type": "exact",
      "rule_expression": "value == '-----'",
      "error_message": "Empty fields must be exactly '-----'"
    },
    {
      "field_name": "empty_fields_2",
      "rule_type": "exact",
      "rule_expression": "value == '---'",
      "error_message": "Empty fields must be exactly '---'"
    },
    {
      "field_name": "final_code",
      "rule_type": "format",
      "rule_expression": "len(value) == 5 and value.isdigit()",
      "error_message": "Final code must be exactly 5 digits"
    }
  ],
  "format_specification": {
    "total_length": 96,
    "field_separator": null,
    "encoding": "utf-8",
    "validation_pattern": "^[A-Z0-9]{4}[A-Z0-9]{3}\\.\\.\\.[0-9]{7}[A-Z]{2}[0-9]{10}[A-Z0-9][A-Z0-9]{5}[A-Z0-9]{2}-----[0-9]{13}[A-Z0-9]{4}[+-][0-9]{6}[+-][0-9]{6}[0-9]{12}---[0-9]{5}$"
  },
  "semantic_domains": null
}