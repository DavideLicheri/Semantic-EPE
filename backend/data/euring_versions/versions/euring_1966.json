  "validation_rules": [
    {
      "field_name": "species_code",
      "rule_type": "format",
      "rule_expression": "value.isdigit() and len(value) == 4",
      "error_message": "Species code must be exactly 4 digits"
    },
    {
      "field_name": "ring_number",
      "rule_type": "format",
      "rule_expression": "len(value) == 7 and value[:2].isalpha() and value[2:].isdigit()",
      "error_message": "Ring number must be 2 uppercase letters followed by 5 digits"
    },
    {
      "field_name": "age_code",
      "rule_type": "range",
      "rule_expression": "value in ['1', '2', '3', '4', '5', '6', '7', '8', '9']",
      "error_message": "Age code must be a single digit from 1 to 9"
    },
    {
      "field_name": "date_code",
      "rule_type": "format",
      "rule_expression": "len(value) == 8 and value.isdigit() and 1 <= int(value[:2]) <= 31 and 1 <= int(value[2:4]) <= 12",
      "error_message": "Date must be 8 digits in valid DDMMYYYY format"
    },
    {
      "field_name": "latitude",
      "rule_type": "format",
      "rule_expression": "len(value) == 5 and value[:-1].isdigit() and value[-1] in ['N', 'S'] and 0 <= int(value[:2]) <= 90 and 0 <= int(value[2:4]) <= 59",
      "error_message": "Latitude must be valid degrees (00-90) and minutes (00-59) followed by N or S"
    },
    {
      "field_name": "longitude",
      "rule_type": "format",
      "rule_expression": "len(value) == 6 and value[:-1].isdigit() and value[-1] in ['E', 'W'] and 0 <= int(value[:3]) <= 180 and 0 <= int(value[3:5]) <= 59",
      "error_message": "Longitude must be valid degrees (000-180) and minutes (00-59) followed by E or W"
    },
    {
      "field_name": "condition_code",
      "rule_type": "format",
      "rule_expression": "len(value) == 2 and value.isdigit()",
      "error_message": "Condition code must be exactly 2 digits"
    },
    {
      "field_name": "method_code",
      "rule_type": "format",
      "rule_expression": "len(value) == 1 and value.isdigit()",
      "error_message": "Method code must be exactly 1 digit"
    },
    {
      "field_name": "wing_length",
      "rule_type": "format",
      "rule_expression": "len(value) == 3 and value.isdigit()",
      "error_message": "Wing length must be exactly 3 digits"
    },
    {
      "field_name": "weight",
      "rule_type": "format",
      "rule_expression": "len(value) == 4 and value.isdigit()",
      "error_message": "Weight must be exactly 4 digits"
    },
    {
      "field_name": "bill_length",
      "rule_type": "format",
      "rule_expression": "len(value) == 4 and value.isdigit()",
      "error_message": "Bill length must be exactly 4 digits"
    }
  ],
  "format_specification": {
    "total_length": 55,
    "field_separator": " ",
